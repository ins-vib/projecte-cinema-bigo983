@startuml

' ===== DOMINI =====

class Cinema {
    # id: long
    # cinemaName: String
    # address: String
    # city: String
    # postalCode: Integer

    + Cinema()
    + Cinema(cinemaName: String, address: String, city: String, postalCode: Integer)
    + getId(): long
    + setId(id: long)
    + getCinemaName(): String
    + setCinemaName(cinemaName: String)
    + getAddress(): String
    + setAddress(address: String)
    + getCity(): String
    + setCity(city: String)
    + getPostalCode(): Integer
    + setPostalCode(postalCode: Integer)
    + getRooms(): List<Room>
    + setRooms(rooms: List<Room>)
}

class Room {
    # id: long
    # name: String
    # capacity: int

    + Room()
    + Room(capacity: int, name: String)
    + getId(): long
    + setId(id: long)
    + getName(): String
    + setName(name: String)
    + getCapacity(): int
    + setCapacity(capacity: int)
    + getCinema(): Cinema
    + setCinema(cinema: Cinema)
    + getSeats(): List<Seat>
    + setSeats(seats: List<Seat>)
}

class Seat {
    # id: long
    # seatRow: String
    # number: int
    # x: int
    # y: int
    # state: boolean
    # typeSeat: SeatType

    + Seat()
    + Seat(number: int, x: int, y: int, seatRow: String, room: Room)
    + getId(): long
    + setId(id: long)
    + getSeatRow(): String
    + setSeatRow(seatRow: String)
    + getNumber(): int
    + setNumber(number: int)
    + getX(): int
    + setX(x: int)
    + getY(): int
    + setY(y: int)
    + isState(): boolean
    + setState(state: boolean)
    + getTypeSeat(): SeatType
    + setTypeSeat(typeSeat: SeatType)
    + getRoom(): Room
    + setRoom(room: Room)
}

enum SeatType {
    STANDARD
    PREMIUM
    ADAPTED
}

class Movie {
    # id: long
    # title: String
    # duration: int
    # genre: String
    # description: String
    # releaseDate: LocalDate

    + Movie()
    + Movie(title: String, duration: int, genre: String, description: String, releaseDate: LocalDate)
    + getId(): long
    + setId(id: long)
    + getTitle(): String
    + setTitle(title: String)
    + getDuration(): int
    + setDuration(duration: int)
    + getGenre(): String
    + setGenre(genre: String)
    + getDescription(): String
    + setDescription(description: String)
    + getReleaseDate(): LocalDate
    + setReleaseDate(releaseDate: LocalDate)
}

class Screening {
    # id: long
    # dateTime: LocalDateTime
    # price: double

    + Screening()
    + getId(): long
    + setId(id: long)
    + getDateTime(): LocalDateTime
    + setDateTime(dateTime: LocalDateTime)
    + getPrice(): double
    + setPrice(price: double)
    + getMovie(): Movie
    + setMovie(movie: Movie)
    + getRoom(): Room
    + setRoom(room: Room)
}

class User {
    # id: Long
    # username: String
    # password: String
    # role: Role

    + User()
    + getId(): Long
    + setId(id: Long)
    + getUsername(): String
    + setUsername(username: String)
    + getPassword(): String
    + setPassword(password: String)
    + getRole(): Role
    + setRole(role: String)
}

enum Role {
    ADMIN
    CLIENT
}

class New {
    # headline: String
    # body: String

    + New(headline: String, body: String)
    + getHeadline(): String
    + setHeadline(headline: String)
    + getBody(): String
    + setBody(body: String)
}

' ===== DTOs =====

class SeatsListDTO <<DTO>> {
    # screeningId: Long
    # seatIds: List<Long>

    + getScreeningId(): Long
    + setScreeningId(screeningId: Long)
    + getSeatIds(): List<Long>
    + setSeatIds(seatIds: List<Long>)
}

class ServicesListDTO <<DTO>> {
    # services: List<String>

    + getServices(): List<String>
    + setServices(services: List<String>)
}

' ===== RELACIONS =====

Cinema "1" -- "0..*" Room : has >
Room "1" -- "0..*" Seat : has >
Seat --> SeatType
Screening "0..*" --> "1" Movie
Screening "0..*" --> "1" Room
User --> Role

@enduml
